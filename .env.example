# Telegram Bot credentials
TELEGRAM_BOT_TOKEN=7801370308:AAF-zPF_atde1cicesa7mTGzZkPQQ4EQjaY
TELEGRAM_CHAT_ID=923740487

# Timezone and daily send schedule
TIMEZONE=Asia/Singapore
SEND_HOUR=6
SEND_MINUTE=0

# Weekly outlook schedule. Monday is 0, Sunday is 6.
ENABLE_WEEKLY_UPDATE=true
WEEKLY_SEND_DAY=0
WEEKLY_SEND_HOUR=6
WEEKLY_SEND_MINUTE=0

# Data source
FF_JSON_URL=https://nfs.faireconomy.media/ff_calendar_thisweek.json
FF_CALENDAR_URL=https://www.forexfactory.com/calendar
ENABLE_SELENIUM_FALLBACK=true

# Networking and retries
REQUEST_TIMEOUT=15
MAX_RETRIES=3
RETRY_BACKOFF_SECONDS=5

# Event filters
IMPACT_FILTER=HIGH,MEDIUM
CURRENCY_FILTER=USD,EUR,GBP,JPY,AUD,CAD,CHF,NZD

# Calendar export
ENABLE_ICS_EXPORT=true
CALENDAR_REMINDER_MINUTES=15
EXPORT_FOLDER=exports
EXPORT_FILE_MAX_AGE_HOURS=24

# GitHub Pages calendar publishing
ENABLE_GITHUB_ICS_PUBLISH=true
CALENDAR_URL=https://liphng.github.io/forex-calendar/calendar.ics
GITHUB_ICS_FILENAME=calendar.ics

# Local/VPS publishing path. Railway does not use this.
GITHUB_REPO_PATH=/Users/liphng/Downloads/forex-calendar

# Railway publishing path. Create a fine-grained GitHub token with
# Contents: Read and write access to the Pages repo.
GITHUB_TOKEN=
GITHUB_OWNER=liphng
GITHUB_PAGES_REPO=forex-calendar
GITHUB_PAGES_BRANCH=main
